# =============================================================================
# Veriora 組織OS — 環境変数（新規キーは docs/env-conventions.md に従う）
# - 共通推奨: VERIORA_*（Phase 3 で Settings の互換 alias 予定）
# - 本サービス（IRIE）固有: IRIE_* 推奨
# - 既存キー名は後方互換のため削除しないでください。
# =============================================================================
#
# IRIE 環境変数テンプレート（.env にコピーして値を埋める）
# 秘密はコミットしない

# --- Google Sheets ---
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_SUMMARY=月次サマリー
SHEET_RECEIVABLES=入金予定
SHEET_PAYABLES=支払予定
HEADER_ROW=1
HEADER_ROW_AUTO=true
DATA_START_ROW=2
MAX_DATA_ROWS=5000

# --- 公開 URL ---
PUBLIC_APP_URL=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_AUDIT_TABLE=irie_audit_log

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- LINE ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# グループ／ルーム: メンションまたは名前呼びがあるときのみ返信（1:1は常に返信）
LINE_BOT_NAME_ALIASES=いり,イリ,IRIE,irie
# 任意: Bot の LINE userId（isSelf が無いクライアント向け）
LINE_BOT_USER_ID=
# 運用メイングループ（LINE groupId。例: Cxxxxxxxx...）
LINE_MAIN_GROUP_ID=
# グループの無言メッセージも RITS に転送（GID 特定に便利。1 / true で有効）
VERIORA_RITS_GROUP_OBSERVE=1
