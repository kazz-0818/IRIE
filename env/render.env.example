# =============================================================================
# Veliora 組織OS — 環境変数（新規キーは docs/env-conventions.md）
# - 既存キー名は削除しないでください。
# =============================================================================
#
# Render（LIRA 単体サービス）用の環境変数例
# Render ダッシュボードの Environment に同名で登録する。

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
SPREADSHEET_ID=your_spreadsheet_id_here
# 未設定でも自動判定可。古い「月次サマリー」等が残っていると優先されるので削除 or 実タブ名へ
# SHEET_SUMMARY=事業実績表(26.3-27.8)
# SHEET_RECEIVABLES=スポンサー管理FILE
# SHEET_PAYABLES=経費詳細
HEADER_ROW=1
HEADER_ROW_AUTO=true
# DATA_START_ROW=2  # コード未使用（将来用）。Render では省略可
MAX_DATA_ROWS=5000

PUBLIC_APP_URL=https://your-irie-service.onrender.com

# --- OpenAI（BRANDVOX 実シートの読み取りに推奨）---
# OPENAI_API_KEY=
# --- Supabase / LINE（任意）---
# OPENAI_MODEL=gpt-4o-mini
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_AUDIT_TABLE=irie_audit_log
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
